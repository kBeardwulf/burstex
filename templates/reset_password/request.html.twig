{% extends 'base.html.twig' %}

{% block title %}Réinitialisation de mot de passe{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('reset_password_error') %}
        <div class="alert alert-danger mt-5" role="alert">{{ flash_error }}</div>
    {% endfor %}
    <h1 mt-5>Réinitialiser votre mot de passe</h1>

    {{ form_start(requestForm) }}
        {{ form_row(requestForm.email) }}
        <div>
            <small>
                Entrez votre e-mail pour recevoir une demande de changement de mot de passe.<br>
                Si votre addresse email est enregistré, vous recevrez un e-mail avec un lien de réinitialisation.
            </small>
        </div>

        <button class="btn btn-primary">Envoyez l'email de réinitialisation</button>
    {{ form_end(requestForm) }}
{% endblock %}