<script src="https://cdn.jsdelivr.net/npm/sortablejs@1.15.0/Sortable.min.js"></script>
<script>
    const list = document.getElementById('players-list');
    const orderInput = document.getElementById('players-order');

    function updateOrder() {
        // On récupère tous les éléments qui ont un attribut data-id
        const elements = list.querySelectorAll('[data-id]');
        
        // On crée un tableau vide pour stocker les ids
        const ids = [];
        
        // Pour chaque élément, on récupère son data-id et on l'ajoute au tableau
        for (let i = 0; i < elements.length; i++) {
            ids.push(elements[i].dataset.id);
        }
        
        // On transforme le tableau en string séparée par des virgules
        // car input type="hidden" ne peux lire que des strings
        // ex: [1, 3, 2] devient "1,3,2"
        orderInput.value = ids.join(',');
    }

    updateOrder();

    new Sortable(list, {
        animation: 150,
        onEnd: updateOrder
    });
</script>