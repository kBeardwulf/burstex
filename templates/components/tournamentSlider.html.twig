<script>
document.addEventListener('DOMContentLoaded', function () {
  (function () {
    const track = document.getElementById('tournamentTrack');
    const dots  = document.querySelectorAll('#tournamentDots .dot');
    const total = dots.length;
    let current = 0;

    function goTo(n) {
      current = (n + total) % total;
      track.style.transform = `translateX(-${current * 100}%)`;
      dots.forEach((d, i) => {
        d.classList.toggle('dot--active', i === current);
      });
    }

    document.getElementById('tournamentPrev').addEventListener('click', () => goTo(current - 1));
    document.getElementById('tournamentNext').addEventListener('click', () => goTo(current + 1));

    let startX = 0, dragging = false;

    function onStart(x) {
      startX = x;
      dragging = true;
      track.style.transition = 'none';
    }

    function onEnd(x) {
      if (!dragging) return;
      dragging = false;
      track.style.transition = 'transform 0.35s cubic-bezier(.4,0,.2,1)';
      if (Math.abs(x - startX) > 40) goTo(x < startX ? current + 1 : current - 1);
      else goTo(current);
    }

    track.addEventListener('mousedown',  e => onStart(e.clientX));
    window.addEventListener('mouseup',   e => onEnd(e.clientX));
    track.addEventListener('touchstart', e => onStart(e.touches[0].clientX), { passive: true });
    track.addEventListener('touchend',   e => onEnd(e.changedTouches[0].clientX), { passive: true });
  })();
});
</script>