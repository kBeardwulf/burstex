{% extends 'base.html.twig' %}

{% block title %}{{ tournament is defined ? 'Modifier' : 'Créer' }} un tournoi{% endblock %}

{% block body %}
    {% for flash_error in app.flashes('verify_email_error') %}
        <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
    {% endfor %}

    <h1 class="text-center mt-5">{{ isEdit ? 'Modifier le tournoi' : 'Créer un tournoi' }}</h1>

    {{ form_errors(tournamentForm) }}

    {{ form_start(tournamentForm, {'attr': {'data-turbo': 'false'}}) }}
        
        {{ form_row(tournamentForm.name) }}

        <div class="row">
            <div class="col">
                {{ form_row(tournamentForm.date) }}
            </div>

            <div class="col">
                {{ form_row(tournamentForm.end_date) }}
            </div>
            
            <div class="col">
                {{ form_row(tournamentForm.price) }}
            </div>
        </div>

        {{ form_row(tournamentForm.discipline) }}

        <div class="row">
            <div class="col">
                {{ form_row(tournamentForm.location) }}
            </div>
            
            <div class="col">
                {{ form_row(tournamentForm.address) }}
            </div>

            <div class="col">
                {{ form_row(tournamentForm.max_nb) }}
            </div>
        </div>

        {{ form_row(tournamentForm.mail) }}

        {% if isEdit == false %}
            {{ form_row(tournamentForm.agreeTerms) }}
        {% endif %}
        
        <div class="text-center">
        <button type="submit" class="btn btn-danger">
            {% if isEdit == false %}
                Créer le tournoi
            {% else %}
                Modifier le tournoi
            {% endif %}
        </button>
        {% if isEdit %}
            <a href="{{ path('app_tour_bracket', {'id': tournament.id}) }}" class="btn btn-success">Voir le bracket</a>
            <a href="{{ path('app_tour_show', {'id': tournament.id}) }}" class="btn btn-dark">Retourner au tournoi</a>
        {% endif %}
        </div>

    {{ form_end(tournamentForm) }}
    {% if isEdit is defined and isEdit %}
        <hr>
        <section>
            <div class="pt-2">
                <div class="d-flex gap-2 mb-4">
                    <h4>Ordre des participants</h4>
                    <form method="post" action="{{ path('app_tour_seed', {'id': tournament.id}) }}">
                    <button type="submit" class="btn btn-danger">Sauvegarder l'ordre</button>
                </div>
                    <input type="hidden" name="_token" value="{{ csrf_token('seed' ~ tournament.id) }}">
                    <input type="hidden" name="order" id="players-order" value="">
                    
                    {# added a board where administrator and organizers can modify seeding #}
                    <div class="d-flex gap-2 mx-auto" style="max-width: 600px;">
                        {# Static numbers on the left side #}
                        <div class="d-flex flex-column">
                            {% for registered in players %}
                                <div class="d-flex align-items-center justify-content-center" 
                                    style="height: 53px; width: 30px;">
                                    <span class="text-muted fw-bold">{{ loop.index }}</span>
                                </div>
                            {% endfor %}
                        </div>
                        {# drag & droppable player list#}
                        <div id="players-list" class="list-group w-100">
                            {% for registered in players %}
                                <div class="list-group-item d-flex align-items-center gap-2" data-id="{{ registered.id }}">

                                    {% if registered.user.profilePic %}
                                        <img src="{{ asset('uploads/profiles/' ~ registered.user.profilePic) }}" 
                                            class="rounded-circle" style="width: 35px; height: 35px; object-fit: cover;">
                                    {% else %}
                                        <div class="rounded-circle bg-danger d-flex align-items-center justify-content-center flex-shrink-0"
                                            style="width: 35px; height: 35px;">
                                            <span class="text-white fw-bold">{{ registered.user.pseudo|first|upper }}</span>
                                        </div>
                                    {% endif %}

                                    <span>{{ registered.user.pseudo }}</span>

                                    {% if registered.seed %}
                                        <span class="badge bg-secondary ms-auto">seeding avant sauvegarde : #{{ registered.seed }}</span>
                                    {% endif %}

                                </div>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="text-center">
                        <button type="submit" class="btn btn-danger mt-3">Sauvegarder l'ordre</button>
                        <a href="{{ path('app_tour_bracket', {'id': tournament.id}) }}" class="btn btn-success mt-3">Voir le bracket</a>
                        <a href="{{ path('app_tour_show', {'id': tournament.id}) }}" class="btn btn-dark mt-3">Retourner au tournoi</a>
                    </div>
                </form>
            </div>
        </section>
        {{ include('components/sortablePlayers.html.twig') }}
    {% endif %}
{% endblock %}