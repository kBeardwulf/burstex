{% extends 'base.html.twig' %}

{% block title %}Tout les tournois{% endblock %}

{% block body %}

<section>
    
    <div class="container mt-4">
        <h1>Tous les tournois</h1>

        {# Champ commun #}
        <form method="get" action="{{ path('app_tour_list') }}">
            <div class="d-flex">
                <input class="form-control form-control-lg customSearchBar" name="search" type="text" placeholder="Rechercher un tournoi...">
                <button type="submit" class=" ms-3 btn btn-primary px-3">Rechercher</button>
            </div>

            {# Des filtres pour le tri #}
            <div class="d-flex flex-row gap-2 mt-2">
                <label class="form-check-label mt-1">Date d'intervalle</label>
            </div>
            <div class="d-flex flex-row gap-2">
                <input class="form-control" type="date" name="date_from">
                <input class="form-control" type="date" name="date_to">
                <input class="form-control" type="number" name="max_nb" placeholder="Nb participants">
            </div>
            
            {# filtres radio #}
            <div class="mt-2 d-flex gap-3 justify-content-center">
                <div>
                    <label class="form-check-label ">Tournois</label>
                    <input class="form-check-input custom-alignment" type="radio" name="type" value="tournament" checked> 
                </div>
                <div>
                    <label class="form-check-label ">Utilisateurs</label>
                    <input class="form-check-input custom-alignment" type="radio" name="type" value="user"> 
                </div>
                <div>
                    <label class="form-check-label ">Afficher uniquement les tournois non commencé</label>
                    <input class="form-check-input custom-alignment" type="checkbox" name="not_started" value="user"> 
                </div>
            </div>
        </form>

        <div class="row row-cols-1 row-cols-md-3 g-4 mt-2">
            {% for tournament in tournaments %}
                <div class="col">
                    <div class="card h-100 shadow-sm">
                        {# Bannière #}
                        {% if tournament.banner %}
                            <img class="banner-in-listpage card-img-top" src="{{ asset('uploads/banners/' ~ tournament.banner) }}">
                        {% else %}
                            <div class="bg-secondary d-flex align-items-center justify-content-center bannerdiv-in-listpage">
                                <span class="text-white">Aucune bannière</span>
                            </div>
                        {% endif %}

                        <div class="card-body">
                            {# Icone + Titre #}
                            <div class="d-flex align-items-center gap-2 mb-2">
                                {% if tournament.icon %}
                                    <img src="{{ asset('uploads/banners/' ~ tournament.icon) }}" class="rounded-2 icon-in-listpage">
                                {% else %}
                                    <div class="icondiv-in-listpage rounded-2 bg-danger d-flex align-items-center justify-content-center flex-shrink-0">
                                        <span class="text-white fw-bold">{{ tournament.name|first|upper }}</span>
                                    </div>
                                {% endif %}
                                <h5 class="card-title mb-0">{{ tournament.name }}</h5>
                            </div>

                            <span class="badge bg-primary mb-2">{{ tournament.discipline }}</span>

                            <p class="card-text">
                                <small>📅 {{ tournament.date|date('d/m/Y') }} → {{ tournament.endDate|date('d/m/Y') }}</small><br>
                                <small>📍 {{ tournament.location ? tournament.location.name : 'En ligne' }}</small><br>
                                <small>💰 {{ tournament.price ? tournament.price ~ ' €' : 'Gratuit' }}</small>
                            </p>

                            <p class="card-text">
                                <small class="text-muted">Créé par <strong>{{ tournament.createdBy ? tournament.createdBy.pseudo : 'Inconnu' }}</strong></small>
                            </p>
                        </div>

                        <div class="card-footer bg-danger">
                            <a href="{{ path('app_tour_show', {'id': tournament.id}) }}" class="btn btn-sm w-100 check-tournament-btn">Voir le tournoi</a>
                        </div>
                    </div>
                </div>
            {% else %}
                <p class="text-muted">Aucun tournoi pour le moment.</p>
            {% endfor %}
        </div>
    </div>

</section>
{% endblock %}