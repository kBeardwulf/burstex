{% extends 'base.html.twig' %}

{% block title %}Page d'accueil{% endblock %}

{% block body %}


<section class="mb-5">
    <div class="text-center">
        <img class="logo-resize" src="{{ asset('images/BURST.ex.png') }}">
    </div>
    <div class="text-center mt-5 mb-4">
        <a class="btn btn-success btn-lg" href="{{ path('app_tour_create') }}">Créer mon tournoi</a>
    </div>
    <h3 class="text-center mb-5">Ou alors</h3>
    <div id="search-container">

        {# Champ commun #}
        <form method="get" action="{{ path('app_tour_list') }}">
            <div class="d-flex">
                <input class="form-control form-control-lg customSearchBar" name="search" type="text" placeholder="Rechercher un tournoi...">
                <button type="submit" class=" ms-3 btn btn-primary px-3">Rechercher</button>
            </div>

            {# Des filtres pour le tri #}
            <div class="d-flex flex-row gap-2 mt-2">
                <label class="form-check-label mt-1">Date d'intervalle</label>
            </div>
            <div class="d-flex flex-row gap-2">
                <input class="form-control" type="date" name="date_from">
                <input class="form-control" type="date" name="date_to">
                <input class="form-control" type="number" name="max_nb" placeholder="Nb participants">
            </div>
            
            {# filtres radio #}
            <div class="mt-2 d-flex gap-3 justify-content-center">
                <div>
                    <label class="form-check-label ">Tournois</label>
                    <input class="form-check-input custom-alignment" type="radio" name="type" value="tournament" checked> 
                </div>
                <div>
                    <label class="form-check-label ">Utilisateurs</label>
                    <input class="form-check-input custom-alignment" type="radio" name="type" value="user"> 
                </div>
                <div>
                    <label class="form-check-label ">Afficher uniquement les tournois non commencé</label>
                    <input class="form-check-input custom-alignment" type="checkbox" name="not_started" value="user"> 
                </div>
            </div>
        </form>

    </div>
</section>


<div class="mt-4">
    <h4 class="mb-3">Tournois récents</h4>
    <section class="splide" aria-label="Tournois récents"> <!-- class splide is where you pass the JS options-->
        <div class="splide__track"> <!-- splide track hides every information that goes above the visible window -->
            <ul class="splide__list"> <!-- this provides all the slides -->
                {% for tournament in tournaments %}
                <li class="splide__slide"> <!-- this is one slide -->
                    <a href="{{ path('app_tour_show', {'id': tournament.id}) }}" class="tour-card-link">
                        <div class="tour-card">
                            {# Bannière #}
                            {% if tournament.banner %}
                                <img src="{{ asset('uploads/banners/' ~ tournament.banner) }}" class="tour-card-banner">
                            {% else %}
                                <div class="tour-card-banner tour-card-banner--empty">
                                    <span>Aucune bannière</span>
                                </div>
                            {% endif %}

                            {# Icone + Titre #}
                            <div class="tour-card-body">
                                <div class="d-flex align-items-center gap-2 mb-1">
                                    {% if tournament.icon %}
                                        <img src="{{ asset('uploads/banners/' ~ tournament.icon) }}" class="tour-card-icon rounded-2">
                                    {% else %}
                                        <div class="tour-card-icon tour-card-icon--placeholder rounded-2">
                                            <span>{{ tournament.name|first|upper }}</span>
                                        </div>
                                    {% endif %}
                                    <p class="tour-card-name">{{ tournament.name }}</p>
                                </div>
                                <span class="tour-card-date">{{ tournament.date|date('d M Y') }} → {{ tournament.endDate|date('d M Y') }}</span>
                            </div>
                        </div>
                    </a>
                </li>
                {% endfor %}
            </ul>
        </div>
    </section>
</div>

{{ include('components/splide.html.twig') }}

<section>
    <div class="text-center mt-5">
        <h2>Tournoi en vedette</h2>
        <div class="card mb-3">
            <img src="..." class="card-img-top" alt="...">
            <div class="card-body">
                <h5 class="card-title">Card title</h5>
                <p class="card-text">This is a wider card with supporting text below as a natural lead-in to additional content. This content is a little bit longer.</p>
                <p class="card-text"><small class="text-muted">Last updated 3 mins ago</small></p>
            </div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">An item</li>
            </ul>
        </div>
    </div>
</section>

{% endblock %}
