<div class="mt-5"></div>
<footer id="main-footer">
    <div class="container">
        <div class="footer-grid">
            
            {# Colonne logo #}
            <div class="footer-col">
                <span class="footer-brand">Burst<span class="brand-dot">.ex</span></span>
                <p class="footer-desc">La plateforme de gestion de tournois compétitifs. Créez, gérez et participez à des tournois en ligne ou en présentiel.</p>
            </div>

            {# Colonne navigation #}
            <div class="footer-col">
